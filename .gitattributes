# Deploy assets run on the Linux VM. Force LF regardless of a contributor's
# core.autocrlf so the shell script's shebang and the systemd unit files never
# arrive with CRLF (CRLF breaks `#!/usr/bin/env bash` and confuses systemd).
*.sh              text eol=lf
deploy/*.service  text eol=lf
deploy/*.timer    text eol=lf
deploy/*.sudoers  text eol=lf
deploy/*.env.example text eol=lf
