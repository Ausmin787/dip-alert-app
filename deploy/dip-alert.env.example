# Copy this to /etc/dip-alert/dip-alert.env on the VM, fill in real values,
# then: sudo chown root:root /etc/dip-alert/dip-alert.env && sudo chmod 600 it.
# This file holds secrets and lives OUTSIDE the git checkout. Never commit the real one.

# Long random string. With it set, every write endpoint requires the X-App-Token
# header and /docs + /openapi.json are auto-disabled. Generate e.g. with:
#   openssl rand -hex 32
APP_TOKEN=replace-with-a-long-random-string

# Absolute path to the SQLite file. NOTE the 4 slashes: sqlite://// + /var/...
# Keeping the DB outside the checkout means `git pull`/re-clone never touches it.
DATABASE_URL=sqlite:////var/lib/dip-alert/dip_alert.db

# Your friend's deployed Vercel frontend origin (for CORS).
FRONTEND_ORIGIN=https://your-vercel-app.vercel.app
